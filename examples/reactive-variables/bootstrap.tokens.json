{
  "bootstrap": {
    "color": {
      "$type": "color",
      "black": {
        "$value": "#1a171b"
      },
      "white": {
        "$value": "#ffffff"
      },
      "primary": {
        "$value": "#de307a"
      },
      "primaryContrast": {
        "$value": "{bootstrap.color.white}"
      },
      "secondary": {
        "$value": "#ffc3dd"
      }
    },
    "spacing": {
      "$type": "dimension",
      "base": {
        "$value": {
          "value": 16,
          "unit": "px"
        }
      },
      "compact": {
        "$value": "{bootstrap.spacing.base}"
      }
    }
  }
}
